# Required
OPENAI_API_KEY=sk-...
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/warren

# ChromaDB storage (created on first run)
CHROMA_PERSIST_DIR=./rag_data

# OpenAI models (defaults shown)
OPENAI_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TIMEOUT_SECONDS=30

# RAG retrieval
RAG_TOP_K=3

# Server
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
